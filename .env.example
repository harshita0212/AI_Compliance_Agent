# Copy to .env and fill in. .env is gitignored.

# Gemini — paste your key from https://aistudio.google.com/apikey
# When a key is present, Gemini runs alongside keyword matching automatically.
# Leave blank to run keyword-only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

RULE_CORPUS_VERSION=2026.06.1
RULES_DIR=app/data/rules

CONFIDENCE_THRESHOLD=0.70
MIN_CONSENT_RATE=1.0

AUDIT_DB_PATH=audit_log.db
