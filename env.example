# Copy to .env and fill in. .env is gitignored.

# Gemini — paste your key from https://aistudio.google.com/apikey
# When a key is present, Gemini runs alongside keyword matching automatically.
# Leave blank to run keyword-only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

RULE_CORPUS_VERSION=2026.06.1
RULES_DIR=app/data/rules

CONFIDENCE_THRESHOLD=0.70
MIN_CONSENT_RATE=1.0

# --- Database ---
# Leave DATABASE_URL blank to use a local SQLite file (AUDIT_DB_PATH).
# Set it to a Postgres DSN to use Postgres instead:
#   postgresql://postgres:YOUR_PASSWORD@localhost:5432/compliance_agent
DATABASE_URL=
AUDIT_DB_PATH=audit_log.db

# --- Access control (DEMO) ---
# Roles are enforced by the backend. The demo ships with two built-in users
# (no setup needed): X-API-Key "marketer-key" (role: marketer) and
# "officer-key" (role: compliance_officer). Marketers can submit and read;
# only compliance officers can review/override flagged campaigns.
# In production these are replaced by company SSO (SAML/OIDC) + a secrets store.
